{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/session-start-hook.py"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/stop-hook-git-check.sh"
                    },
                    {
                        "type": "command",
                        "command": "~/.claude/anti-fabrication-hook.py"
                    },
                    {
                        "type": "command",
                        "command": "~/.claude/cascade-enforcement-hook.py"
                    },
                    {
                        "type": "command",
                        "command": "~/.claude/segment-trajectory-hook.py"
                    },
                    {
                        "type": "command",
                        "command": "~/.claude/nth-order-cascade-hook.py"
                    },
                    {
                        "type": "command",
                        "command": "~/.claude/bypass-route-hook.py"
                    },
                    {
                        "type": "command",
                        "command": "~/.claude/bottoms-up-hook.py"
                    },
                    {
                        "type": "command",
                        "command": "~/.claude/antifragility-mn-hook.py"
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": ["Skill"]
    }
}
